LINKEDIN_EMAIL=your_email@gmail.com
LINKEDIN_PASSWORD=your_password

# Lay tu Chrome: F12 -> Application -> Cookies -> linkedin.com
LI_AT=your_li_at_value
JSESSIONID="ajax:your_jsessionid_value"
BCOOKIE="v=2&your_bcookie_value"
BSCOOKIE="v=1&your_bscookie_value"

# ── Groq AI (cham do phu hop CV <-> JD) ──
# Lay key tai https://console.groq.com/keys
# Ho tro ca GROQ_API_KEY (uu tien) va GROG_API_KEY (ten cu)
GROQ_API_KEY=your_groq_api_key

# ── Job Matcher (match_jobs.py) ──
# Bo loc crawl LinkedIn:
CRAWL_KEYWORDS=marketing,truyen thong,su kien
CRAWL_LOCATION=Hanoi
CRAWL_MAX_PAGES=3
CRAWL_DATE_POSTED=week         # 24h | week | month | any
CRAWL_EXPERIENCE=             # entry | mid_senior | ... (rong = tat ca)
CRAWL_WORK_TYPE=              # onsite | remote | hybrid (rong = tat ca)
# CV cua ban (de trong = tu dong tim file dau tien trong thu muc cv/)
CV_PATH=
# Chi giu job co do phu hop >= MIN_SCORE, lay toi da MAX_RESULTS job
MIN_SCORE=70
MAX_RESULTS=20

# ── Gui email ket qua crawl ──
# MAC DINH TAT. Dat SEND_EMAIL=1 de bat lai (can GMAIL_USER / GMAIL_APP_PASSWORD / EMAIL_TO)
SEND_EMAIL=0
# GMAIL_USER=your_email@gmail.com
# GMAIL_APP_PASSWORD=your_app_password
# EMAIL_TO=recipient@gmail.com

# ── Facebook (auto-post len Page) ──
# developers.facebook -> Cai dat ung dung -> Co ban
FB_APP_ID=your_fb_app_id
FB_APP_SECRET=your_fb_app_secret
# Token ngan han tu Graph API Explorer (chi dung de doi sang long-lived)
FB_SHORT_TOKEN=EAA_short_lived_token
# Script tu dien sau khi doi long-lived:
FB_PAGE_ID=
FB_PAGE_TOKEN=
