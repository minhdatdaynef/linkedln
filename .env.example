LINKEDIN_EMAIL=your_email@gmail.com
LINKEDIN_PASSWORD=your_password

# Lay tu Chrome: F12 -> Application -> Cookies -> linkedin.com
LI_AT=your_li_at_value
JSESSIONID="ajax:your_jsessionid_value"
BCOOKIE="v=2&your_bcookie_value"
BSCOOKIE="v=1&your_bscookie_value"

# ── Web app (phan tich / xay dung CV theo JD) ──
# Lay key tai https://console.groq.com/keys
# Ho tro ca GROQ_API_KEY (uu tien) va GROG_API_KEY (ten cu)
GROQ_API_KEY=your_groq_api_key

# ── Gui email ket qua crawl ──
# MAC DINH TAT. Dat SEND_EMAIL=1 de bat lai (can GMAIL_USER / GMAIL_APP_PASSWORD / EMAIL_TO)
SEND_EMAIL=0
# GMAIL_USER=your_email@gmail.com
# GMAIL_APP_PASSWORD=your_app_password
# EMAIL_TO=recipient@gmail.com
